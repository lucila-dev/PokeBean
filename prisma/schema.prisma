generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  cards        Card[]
}

model Card {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  displayName String?  // TCGPlayer-style: "Card Name - Set Name (X/YY)"
  description String?
  year        Int?
  setName     String?
  rarity      String?
  cardNumber  String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  @@index([userId])
}
