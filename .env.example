# PostgreSQL via Supabase (recommended for Vercel)
#
# In Supabase: Project Settings → Database → Connection string
#
# DATABASE_URL = "Transaction" pooler (port 6543) — used by the app on Vercel
# DIRECT_URL   = "Session" or direct URI (port 5432) — used for migrations
#
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Local dev (same URL for both is fine)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pokemon_dashboard"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pokemon_dashboard"

# NextAuth — required on Vercel
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

OPENAI_API_KEY="sk-..."
POKEWALLET_API_KEY="pk_live_your-key-here"
