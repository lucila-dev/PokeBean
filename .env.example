# PostgreSQL — required on Vercel (Neon, Supabase, etc.)
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# NextAuth — required on Vercel
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key"
# Local only; on Vercel this is set automatically from VERCEL_URL
NEXTAUTH_URL="http://localhost:3000"

# OpenAI — for card scanning
OPENAI_API_KEY="sk-..."

# PokeWallet catalog API
POKEWALLET_API_KEY="pk_live_your-key-here"
